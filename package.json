{
  "name": "terrain-summit",
  "version": "3.2.2",
  "description": "Terrain Summit - Where every achievement is a Summit conquered",
  "main": "summit.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pete-mc/Summit.git"
  },
  "keywords": [
    "scouts",
    "terrain",
    "summit",
    "contour"
  ],
  "author": "Peter McDonald",
  "license": "MIT",
  "engines": {
    "node": "24.x"
  },
  "bugs": {
    "url": "https://github.com/pete-mc/Summit/issues"
  },
  "homepage": "https://github.com/pete-mc/Summit#readme",
  "scripts": {
    "test": "jest --config jest.config.js",
    "test:browser": "playwright test",
    "test:watch": "jest --config jest.config.js --watch",
    "test:coverage": "jest --config jest.config.js --coverage",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"tests/unit/**/*.ts\" \"tests/browser/**/*.ts\" \"playwright.config.ts\"",
    "build-prod": "webpack --config webpack.config.js --mode production",
    "build": "webpack --config webpack.config.js --mode development",
    "build-watch": "webpack --config webpack.config.js --mode development --watch",
    "start": "webpack-dev-server --config webpack.config.js --mode development"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
