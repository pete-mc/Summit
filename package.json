    "@babel/preset-typescript": "^7.28.5",
    "@playwright/test": "^1.59.1",
    "@types/big.js": "^6.2.2",
    "@types/jest": "^29.5.14",
    "@types/jquery": "^3.5.34",
    "@types/node": "^24.12.2",
