{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install dependencies",
      "type": "shell",
      "command": "npm ci",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Build Summit (development)",
      "type": "shell",
      "command": "npm run build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Build Summit (production)",
      "type": "shell",
      "command": "npm run build-prod",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Package Summit extension artifact",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "New-Item -ItemType Directory -Force artifacts | Out-Null; Remove-Item -Path artifacts/Summit.zip -Force -ErrorAction SilentlyContinue; Compress-Archive -Path dist/* -DestinationPath artifacts/Summit.zip -Force"
      ],
      "dependsOn": "Build Summit (production)",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Watch Summit build",
      "type": "shell",
      "command": "npm run build-watch",
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Start Summit dev server",
      "type": "shell",
      "command": "npm start",
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
